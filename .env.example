# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Used by Claude (answer + summary + agent LLMs) via LiteLLM. Local embeddings need no key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: relocate the paper-qa cache base (parent of .pqa). Not needed —
# each exploration uses its own co-located index/ dir by default.
# PQA_HOME=
